<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <meta name="description" content="{{ description }}">
    {%- if keywords %}
    <meta name="keywords" content="{{ keywords }}">
    {%- endif %}
    {%- if author %}
    <meta name="author" content="{{ author }}">
    {%- endif %}

    <!-- Open Graph -->
    <meta property="og:type" content="{{ ogType or 'website' }}">
    <meta property="og:url" content="{{ canonical }}">
    <meta property="og:title" content="{{ ogTitle or title }}">
    <meta property="og:description" content="{{ ogDescription or description }}">
    <meta property="og:site_name" content="Church & Code">
    <meta property="og:image" content="{{ ogImage or 'https://churchandcode.com/assets/og-image.jpg' }}">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:alt" content="{{ ogImageAlt or 'Church & Code. Catholic perspectives on artificial intelligence.' }}">

    {%- if articleAuthor %}
    <!-- Article metadata -->
    <meta property="article:author" content="{{ articleAuthor }}">
    <meta property="article:published_time" content="{{ articlePublishedTime }}">
    <meta property="article:modified_time" content="{{ articleModifiedTime or articlePublishedTime }}">
    {%- endif %}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="{{ twitterCard or 'summary_large_image' }}">
    <meta name="twitter:title" content="{{ twitterTitle or ogTitle or title }}">
    <meta name="twitter:description" content="{{ twitterDescription or ogDescription or description }}">
    <meta name="twitter:image" content="{{ twitterImage or ogImage or 'https://churchandcode.com/assets/og-image.jpg' }}">
    <meta name="twitter:image:alt" content="{{ ogImageAlt or 'Church & Code. Catholic perspectives on artificial intelligence.' }}">

    <!-- Favicons -->
    <link rel="icon" type="image/x-icon" href="/assets/favicon.ico">
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/assets/favicon-16x16.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/apple-touch-icon.png">
    <link rel="manifest" href="/assets/site.webmanifest">

    <!-- Canonical URL -->
    <link rel="canonical" href="{{ canonical }}">

    {%- if schema %}
    <!-- Schema.org JSON-LD -->
    {%- if schema[0] and schema[0]["@context"] %}
    {%- for item in schema %}
    <script type="application/ld+json">
{{ item | dump | safe }}
    </script>
    {%- endfor %}
    {%- elif schema["@context"] %}
    <script type="application/ld+json">
{{ schema | dump | safe }}
    </script>
    {%- else %}
    <script type="application/ld+json">
{{ schema | safe }}
    </script>
    {%- endif %}
    {%- endif %}

    <link rel="stylesheet" href="/assets/css/style.css">
</head>
<body>
    <!-- Navigation -->
    <nav class="nav">
        <div class="nav-container">
            <a href="/" class="nav-logo">Church & Code</a>
            <button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false">☰</button>
            <ul class="nav-links">
                <li><a href="/">Home</a></li>
                <li><a href="/framework.html">Framework</a></li>
                <li><a href="/news/">News</a></li>
                <li><a href="/pope-leo-xiv-on-ai.html">Pope Leo XIV</a></li>
                <li><a href="/about.html">About</a></li>
            </ul>
        </div>
    </nav>

    {{ content | safe }}

    <footer class="footer">
        <div class="footer-container">
            <p class="footer-text">Church & Code</p>
            <p class="footer-copyright">© 2026 Church & Code. Catholic perspectives on AI ethics.</p>
        </div>
    </footer>

    <script src="/assets/js/nav.js" defer></script>
</body>
</html>
